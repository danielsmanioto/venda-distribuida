# Environment variables for production
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_PASSWORD=change-this-password-in-production

# Redis
REDIS_PASSWORD=change-this-password-in-production

# RabbitMQ
RABBITMQ_PASSWORD=change-this-password-in-production

# Grafana
GRAFANA_PASSWORD=change-this-password-in-production

# GitHub Container Registry
GITHUB_REPOSITORY_OWNER=your-github-username
